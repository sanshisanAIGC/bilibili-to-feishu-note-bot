# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# B站视频 → 飞书文档 AI 笔记系统 - 配置文件
# 复制此文件为 .env 并填入你的实际值
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━ 飞书应用凭证 ━━━━
# 在飞书开放平台 https://open.feishu.cn 创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━ DeepSeek API ━━━━
# 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ━━━━ B站 Cookie ━━━━
# 登录 B站后，从浏览器开发者工具 > Application > Cookies 获取 SESSDATA 的值
BILIBILI_SESSDATA=xxxxxxxxxxxxxxxxxxxx

# ━━━━ Whisper 配置 ━━━━
# 模型大小: tiny, base, small, medium, large
# base 对中文够用且速度快，small 效果更好但更慢
WHISPER_MODEL=base
# 设备: auto (自动检测), cpu, cuda
WHISPER_DEVICE=auto
# 计算类型: auto, float16, int8
WHISPER_COMPUTE_TYPE=auto

# ━━━━ 音频下载配置 ━━━━
# 音频下载目录（默认 ./downloads）
AUDIO_DOWNLOAD_DIR=./downloads
# 浏览器 cookie 来源: chrome, firefox, edge
AUDIO_COOKIE_BROWSER=chrome
